# FRR daemon selection for open-nos-as5610
# Enable zebra (required), bgpd, and ospfd.
# Routes are picked up by nos-switchd via netlink and programmed to the ASIC.

zebra=yes
bgpd=yes
ospfd=yes
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no

# Zebra options: enable FPM for nos-switchd integration if needed
#zebra_options="  -A 127.0.0.1 -s 90000000"
#bgpd_options="   -A 127.0.0.1"
#ospfd_options="  -A 127.0.0.1"
