[Unit]
Description=Load NOS kernel modules (BCM56846 BDE + AS5610 CPLD)
DefaultDependencies=no
After=local-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c 'insmod /lib/modules/$(uname -r)/nos_kernel_bde.ko'
ExecStart=/bin/sh -c 'insmod /lib/modules/$(uname -r)/nos_user_bde.ko'
ExecStart=/bin/sh -c 'insmod /lib/modules/$(uname -r)/accton_as5610_cpld.ko || true'

[Install]
WantedBy=multi-user.target
