		serial@4500 {
			cell-index = <0x00>;
			device_type = "serial";
			compatible = "ns16550";
			reg = <0x4500 0x100>;
			clock-frequency = <0x00>;
			interrupts = <0x2a 0x02>;
		};

		l2-cache-controller@20000 {
			compatible = "fsl,p2020-l2-cache-controller";
			reg = <0x20000 0x1000>;
			cache-line-size = <0x20>;
			cache-size = <0x80000>;
			interrupts = <0x10 0x02>;
		};

		usb@22000 {
			compatible = "fsl-usb2-dr";
			reg = <0x22000 0x1000>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			interrupts = <0x1c 0x02>;
			phy_type = "ulpi";
			dr_mode = "host";
		};

		mdio@24520 {
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			compatible = "fsl,gianfar-mdio";
			reg = <0x24520 0x20>;

			ethernet-phy@1 {
				reg = <0x01>;
				device_type = "ethernet-phy";
				linux,phandle = <0x02>;
