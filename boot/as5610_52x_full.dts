/dts-v1/;

/ {
	model = "accton,as5610_52x";
	compatible = "accton,as5610_52x";
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	interrupt-parent = <0x01>;

	aliases {
		ethernet0 = "/soc@ff700000/ethernet@24000";
		serial0 = "/soc@ff700000/serial@4500";
		pci1 = "/pcie@ff70a000";
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		PowerPC,P2020@0 {
			device_type = "cpu";
			reg = <0x00>;
			next-level-cache = <0x01>;
		};

		PowerPC,P2020@1 {
			device_type = "cpu";
			reg = <0x01>;
			next-level-cache = <0x01>;
		};
	};

	memory {
		device_type = "memory";
	};

	bcm_dma {
		compatible = "early-dma-alloc";
		region_size = <0x4000000>;
		alignment = <0x100000>;
	};

	localbus@ff705000 {
		#address-cells = <0x02>;
		#size-cells = <0x01>;
		compatible = "fsl,p2020-elbc", "fsl,elbc", "simple-bus";
		reg = <0x00 0xff705000 0x00 0x1000>;
		interrupts = <0x13 0x02>;
		ranges = <0x00 0x00 0x00 0xefc00000 0x400000 0x01 0x00 0x00 0xea000000 0x100>;

		flash@0,0 {
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			compatible = "cfi-flash";
			reg = <0x00 0x00 0x400000>;
			bank-width = <0x01>;
			device-width = <0x01>;

			partition@0 {
				reg = <0x00 0x360000>;
				label = "onie";
			};

			partition@1 {
				reg = <0x360000 0x10000>;
				label = "uboot-env";
				env_size = <0x2000>;
			};

			partition@2 {
				reg = <0x370000 0x10000>;
				label = "board_eeprom";
			};

			partition@3 {
				reg = <0x380000 0x80000>;
				label = "uboot";
			};
		};

		cpld@1,0 {
			compatible = "accton,accton_as5610_52x-cpld";
			reg = <0x01 0x00 0x100>;
		};
	};

	soc@ff700000 {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		device_type = "soc";
		compatible = "fsl,p2020-immr", "simple-bus";
		ranges = <0x00 0x00 0xff700000 0x100000>;
		bus-frequency = <0x00>;

		memory-controller@2000 {
			compatible = "fsl,p2020-memory-controller";
			reg = <0x2000 0x1000>;
			interrupts = <0x12 0x02>;
		};

		i2c@3000 {
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			cell-index = <0x00>;
			compatible = "fsl-i2c";
			reg = <0x3000 0x100>;
			interrupts = <0x2b 0x02>;
			dfsrr;
			fsl,timeout = <0x2710>;
			fsl,preserve-clocking;

			mux@70 {
				compatible = "ti,pca9548";
				reg = <0x70>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				i2c@0 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x00>;

					rtc@51 {
						compatible = "epson,rtc8564";
						reg = <0x51>;
					};
				};

				i2c@1 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x01>;

					psu_eeprom@3a {
						compatible = "at,24c02";
						reg = <0x3a>;
						label = "psu1_eeprom";
						read-only;
					};

					psu_unknown@3e {
						compatible = "at,24c02";
						reg = <0x3e>;
						label = "psu1_eeprom";
						read-only;
					};

					psu_eeprom@78 {
						compatible = "at,24c02";
						reg = <0x78>;
						label = "psu1_eeprom";
						read-only;
					};
				};

				i2c@2 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x02>;

					psu_eeprom@0c {
						compatible = "at,24c02";
						reg = <0x0c>;
						label = "psu2_eeprom";
						read-only;
					};

					psu_unknown@39 {
						compatible = "at,24c02";
						reg = <0x39>;
						label = "psu2_eeprom2";
						read-only;
					};

					psu_eeprom@3d {
						compatible = "at,24c02";
						reg = <0x3d>;
						label = "psu2_eeprom";
						read-only;
					};

					psu_eeprom@78 {
						compatible = "at,24c02";
						reg = <0x78>;
						label = "psu2_eeprom";
						read-only;
					};
				};

				i2c@3 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x03>;
				};

				i2c@4 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x04>;
				};

				i2c@5 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x05>;
				};

				i2c@6 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x06>;
				};

				i2c@7 {
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					reg = <0x07>;

					hwmon@4d {
						compatible = "nxp,max6697";
						reg = <0x4d>;
					};

					tmon@18 {
						compatible = "nxp,max1617";
						reg = <0x18>;
					};
				};
			};
		};

		i2c@3100 {
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			cell-index = <0x01>;
			compatible = "fsl-i2c";
			reg = <0x3100 0x100>;
			interrupts = <0x2b 0x02>;
			dfsrr;
			fsl,preserve-clocking;

			mux@75 {
